<!-- Audio Extractor Page — Searchr YouTube Downloader -->

<div class="page-header">
  <h1 class="page-title">
    Audio Extractor
  </h1>
  <p class="page-subtitle">Extract high-quality MP3 or M4A audio from any YouTube video</p>
</div>

<!-- URL Input -->
<div class="glass-card p-4 mb-4">
  <div class="input-group input-group-lg">
    <span class="input-group-text glass-input-icon">
      <i class="fab fa-youtube text-danger"></i>
    </span>
    <input
      type="url"
      id="audioUrl"
      class="form-control glass-input"
      placeholder="Paste YouTube URL here..."
      autocomplete="off"
    >
    <button class="btn btn-accent" type="button" id="fetchAudioBtn">
      <i class="fas fa-search me-1"></i> Fetch Info
    </button>
  </div>
</div>

<!-- Loading Spinner -->
<div id="audioLoading" class="text-center py-5 d-none">
  <div class="spinner-glow">
    <div class="spinner-border text-accent" role="status">
      <span class="visually-hidden">Loading...</span>
    </div>
  </div>
  <p class="mt-3 text-muted">Fetching audio information...</p>
</div>

<!-- Audio Info Card -->
<div id="audioInfoCard" class="d-none">
  <div class="glass-card p-4 mb-4">
    <div class="row g-4 align-items-center">
      <div class="col-md-3">
        <div class="thumbnail-wrapper">
          <img id="audioThumb" src="" alt="Thumbnail" class="img-fluid rounded-3">
          <span id="audioDuration" class="duration-badge"></span>
        </div>
      </div>
      <div class="col-md-9">
        <h3 id="audioTitle" class="mb-2"></h3>
        <p class="text-muted mb-3" style="font-size: 0.9rem;">
          <i class="fas fa-user me-1"></i> <span id="audioUploader"></span>
        </p>

        <!-- Format Selection -->
        <h5 class="mb-3" style="font-weight: 700;">Choose Format</h5>
        <div class="row g-3">
          <div class="col-md-6">
            <div class="glass-card format-select-card p-3 text-center active" data-format="mp3" id="mp3Card">
              <i class="fas fa-file-audio fa-2x mb-2 text-accent"></i>
              <h5>MP3</h5>
              <p class="text-muted small mb-1">Universal Format</p>
              <span class="format-badge">320 kbps</span>
            </div>
          </div>
          <div class="col-md-6">
            <div class="glass-card format-select-card p-3 text-center" data-format="m4a" id="m4aCard">
              <i class="fas fa-file-audio fa-2x mb-2" style="color: var(--accent-live);"></i>
              <h5>M4A</h5>
              <p class="text-muted small mb-1">Apple / AAC Format</p>
              <span class="format-badge">192 kbps</span>
            </div>
          </div>
        </div>

        <!-- Audio Formats Table -->
        <div class="mt-4">
          <h5 class="mb-3" style="font-weight: 700;">Available Audio Streams</h5>
          <div class="table-responsive">
            <table class="table table-glass">
              <thead>
                <tr>
                  <th>Codec</th>
                  <th>Bitrate</th>
                  <th>Size</th>
                  <th>Format</th>
                </tr>
              </thead>
              <tbody id="audioFormatsBody">
                <!-- Populated by JS -->
              </tbody>
            </table>
          </div>
        </div>

        <!-- Download Button -->
        <button class="btn btn-accent btn-lg mt-3 w-100" id="downloadAudioBtn">
          <i class="fas fa-download me-2"></i> Download Audio
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Download Progress -->
<div id="audioDownloadProgress" class="glass-card p-4 d-none">
  <h4 class="mb-3" style="font-weight: 700;">
    <i class="fas fa-download me-2 text-accent"></i>Extracting Audio...
  </h4>
  <div class="progress progress-glow mb-3">
    <div id="audioDownloadBar" class="progress-bar progress-bar-striped progress-bar-animated bg-accent" role="progressbar" style="width: 100%">
      Processing...
    </div>
  </div>
  <p id="audioDownloadStatus" class="text-muted mb-0 small">Please wait while we extract the audio...</p>
</div>

<script src="/js/audio.js"></script>
