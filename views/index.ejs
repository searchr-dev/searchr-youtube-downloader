<!-- Home Page — Searchr YouTube Downloader -->

<!-- ═══ Hero Section ═══ -->
<section class="hero-section text-center">
  <div class="hero-content">
    <h1 class="hero-title">
      <span class="gradient-text">Searchr</span> YouTube<br>Downloader
    </h1>
    <p class="hero-subtitle">
      Download videos, extract audio, clip timestamps & record live streams — all in one place.
    </p>

    <!-- Quick URL Input -->
    <div class="row justify-content-center mt-4">
      <div class="col-lg-7">
        <div class="glass-card p-4">
          <div class="input-group input-group-lg">
            <span class="input-group-text glass-input-icon">
              <i class="fab fa-youtube text-danger"></i>
            </span>
            <input
              type="url"
              id="quickUrl"
              class="form-control glass-input"
              placeholder="Paste a YouTube URL to get started..."
              autocomplete="off"
            >
            <button class="btn btn-accent" type="button" id="quickGoBtn">
              <i class="fas fa-arrow-right me-1"></i> Go
            </button>
          </div>
          <small class="text-muted mt-2 d-block" style="font-size: 0.8rem;">
            <i class="fas fa-shield-alt me-1"></i>
            We detect the best download option for your link automatically.
          </small>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ Feature Cards ═══ -->
<section class="features-section mt-5">
  <div class="row g-4">
    <!-- Video Download -->
    <div class="col-md-6 col-lg-3">
      <a href="/video" class="text-decoration-none">
        <div class="glass-card feature-card h-100 text-center p-4">
          <div class="feature-icon feature-icon-video">
            <i class="fas fa-video"></i>
          </div>
          <h3 class="feature-title">Video Download</h3>
          <p class="feature-desc">
            Download in 144p to 4K. Choose quality, format & codec.
          </p>
          <span class="feature-badge">MP4 / MKV / WEBM</span>
        </div>
      </a>
    </div>

    <!-- Audio Extract -->
    <div class="col-md-6 col-lg-3">
      <a href="/audio" class="text-decoration-none">
        <div class="glass-card feature-card h-100 text-center p-4">
          <div class="feature-icon feature-icon-audio">
            <i class="fas fa-music"></i>
          </div>
          <h3 class="feature-title">Audio Extractor</h3>
          <p class="feature-desc">
            Extract MP3 or M4A in the highest available bitrate.
          </p>
          <span class="feature-badge">MP3 / M4A</span>
        </div>
      </a>
    </div>

    <!-- Clip / Timestamp -->
    <div class="col-md-6 col-lg-3">
      <a href="/clip" class="text-decoration-none">
        <div class="glass-card feature-card h-100 text-center p-4">
          <div class="feature-icon feature-icon-clip">
            <i class="fas fa-cut"></i>
          </div>
          <h3 class="feature-title">Timestamp Clip</h3>
          <p class="feature-desc">
            Download a specific time range. Trim video or audio precisely.
          </p>
          <span class="feature-badge">Start → End</span>
        </div>
      </a>
    </div>

    <!-- Live Stream -->
    <div class="col-md-6 col-lg-3">
      <a href="/live" class="text-decoration-none">
        <div class="glass-card feature-card h-100 text-center p-4">
          <div class="feature-icon feature-icon-live">
            <i class="fas fa-broadcast-tower"></i>
          </div>
          <h3 class="feature-title">Live Stream</h3>
          <p class="feature-desc">
            Record live streams. Set duration or download full recording.
          </p>
          <span class="feature-badge badge-live">● LIVE</span>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- ═══ Stats Section ═══ -->
<section class="stats-section mt-5">
  <div class="glass-card p-4">
    <div class="row text-center g-4">
      <div class="col-6 col-md-3">
        <div class="stat-item">
          <div class="stat-number">4K</div>
          <div class="stat-label">Max Quality</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-item">
          <div class="stat-number">320k</div>
          <div class="stat-label">Audio Bitrate</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-item">
          <div class="stat-number">∞</div>
          <div class="stat-label">No Limits</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-item">
          <div class="stat-number">FREE</div>
          <div class="stat-label">Always Free</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ How It Works ═══ -->
<section class="how-section mt-5 mb-4">
  <h2 class="section-title text-center mb-4">
    How It Works
  </h2>
  <div class="row g-4">
    <div class="col-md-4">
      <div class="glass-card text-center p-4 step-card">
        <div class="step-number">1</div>
        <h4>Paste URL</h4>
        <p>Copy a YouTube link and paste it into the search bar.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="glass-card text-center p-4 step-card">
        <div class="step-number">2</div>
        <h4>Choose Quality</h4>
        <p>Select resolution, format, or audio quality.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="glass-card text-center p-4 step-card">
        <div class="step-number">3</div>
        <h4>Download</h4>
        <p>Click download and get your file instantly.</p>
      </div>
    </div>
  </div>
</section>

<script>
  // Quick URL auto-detect and redirect
  document.getElementById('quickGoBtn')?.addEventListener('click', () => {
    const url = document.getElementById('quickUrl').value.trim();
    if (!url) return showToast('Please enter a YouTube URL', 'warning');
    // Default to video downloader
    window.location.href = '/video?url=' + encodeURIComponent(url);
  });

  document.getElementById('quickUrl')?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') document.getElementById('quickGoBtn').click();
  });
</script>
