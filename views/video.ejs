<!-- Video Downloader Page — Searchr YouTube Downloader -->

<div class="page-header">
  <h1 class="page-title">
    Video Downloader
  </h1>
  <p class="page-subtitle">Download YouTube videos in any quality from 144p to 4K</p>
</div>

<!-- URL Input -->
<div class="glass-card p-4 mb-4">
  <div class="input-group input-group-lg">
    <span class="input-group-text glass-input-icon">
      <i class="fab fa-youtube text-danger"></i>
    </span>
    <input
      type="url"
      id="videoUrl"
      class="form-control glass-input"
      placeholder="Paste YouTube URL here..."
      autocomplete="off"
    >
    <button class="btn btn-accent" type="button" id="fetchVideoBtn">
      <i class="fas fa-search me-1"></i> Fetch Info
    </button>
  </div>
</div>

<!-- Loading Spinner -->
<div id="videoLoading" class="text-center py-5 d-none">
  <div class="spinner-glow">
    <div class="spinner-border text-accent" role="status">
      <span class="visually-hidden">Loading...</span>
    </div>
  </div>
  <p class="mt-3 text-muted">Fetching video information...</p>
</div>

<!-- Video Info Card -->
<div id="videoInfoCard" class="d-none">
  <div class="glass-card p-4 mb-4">
    <div class="row g-4 align-items-center">
      <div class="col-md-4">
        <div class="thumbnail-wrapper">
          <img id="videoThumb" src="" alt="Thumbnail" class="img-fluid rounded-3">
          <span id="videoDuration" class="duration-badge"></span>
        </div>
      </div>
      <div class="col-md-8">
        <h3 id="videoTitle" class="mb-2"></h3>
        <p class="text-muted mb-2" style="font-size: 0.9rem;">
          <i class="fas fa-user me-1"></i> <span id="videoUploader"></span>
          <span class="mx-2">•</span>
          <i class="fas fa-eye me-1"></i> <span id="videoViews"></span>
        </p>
        <p id="videoDesc" class="text-muted small mb-0"></p>
      </div>
    </div>
  </div>

  <!-- Format Table -->
  <div class="glass-card p-4 mb-4">
    <h4 class="mb-3" style="font-weight: 700;">Available Formats</h4>

    <!-- Quality Presets -->
    <div class="quality-presets mb-4">
      <div class="d-flex flex-wrap gap-2">
        <button class="btn btn-quality" data-quality="144">144p</button>
        <button class="btn btn-quality" data-quality="240">240p</button>
        <button class="btn btn-quality" data-quality="360">360p</button>
        <button class="btn btn-quality" data-quality="480">480p</button>
        <button class="btn btn-quality" data-quality="720">720p</button>
        <button class="btn btn-quality" data-quality="1080">1080p</button>
        <button class="btn btn-quality btn-quality-best" data-quality="best">
          <i class="fas fa-crown me-1"></i> Best Quality
        </button>
      </div>
    </div>

    <!-- Formats Table -->
    <div class="table-responsive">
      <table class="table table-glass" id="formatsTable">
        <thead>
          <tr>
            <th>Quality</th>
            <th>Resolution</th>
            <th>Format</th>
            <th>Codec</th>
            <th>FPS</th>
            <th>Bitrate</th>
            <th>Size</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="formatsBody">
          <!-- Populated by JS -->
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Download Progress -->
<div id="downloadProgress" class="glass-card p-4 d-none">
  <h4 class="mb-3" style="font-weight: 700;">
    <i class="fas fa-download me-2 text-accent"></i>Downloading...
  </h4>
  <div class="progress progress-glow mb-3">
    <div id="downloadBar" class="progress-bar progress-bar-striped progress-bar-animated bg-accent" role="progressbar" style="width: 0%">
      0%
    </div>
  </div>
  <p id="downloadStatus" class="text-muted mb-0 small">Preparing download...</p>
  <button id="cancelVideoBtn" class="btn btn-danger-glass btn-sm mt-3 w-100 d-none">
    <i class="fas fa-times me-1"></i> Stop Download
  </button>
</div>

<script src="/js/video.js"></script>
