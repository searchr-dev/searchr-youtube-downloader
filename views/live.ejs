<!-- Live Stream Downloader Page — Searchr YouTube Downloader -->

<div class="page-header">
  <h1 class="page-title">
    Live Stream Downloader
  </h1>
  <p class="page-subtitle">Record and download YouTube live streams in the highest quality</p>
</div>

<!-- URL Input -->
<div class="glass-card p-4 mb-4">
  <div class="input-group input-group-lg">
    <span class="input-group-text glass-input-icon">
      <i class="fab fa-youtube text-danger"></i>
    </span>
    <input
      type="url"
      id="liveUrl"
      class="form-control glass-input"
      placeholder="Paste YouTube Live Stream URL here..."
      autocomplete="off"
    >
    <button class="btn btn-accent" type="button" id="fetchLiveBtn">
      <i class="fas fa-satellite-dish me-1"></i> Detect
    </button>
  </div>
</div>

<!-- Loading Spinner -->
<div id="liveLoading" class="text-center py-5 d-none">
  <div class="spinner-glow">
    <div class="spinner-border text-accent" role="status">
      <span class="visually-hidden">Loading...</span>
    </div>
  </div>
  <p class="mt-3 text-muted">Detecting live stream...</p>
</div>

<!-- Live Info Card -->
<div id="liveInfoCard" class="d-none">
  <div class="glass-card p-4 mb-4">
    <div class="row g-4 align-items-center">
      <div class="col-md-4">
        <div class="thumbnail-wrapper">
          <img id="liveThumb" src="" alt="Thumbnail" class="img-fluid rounded-3">
          <!-- Live Status Badge -->
          <span id="liveStatusBadge" class="live-status-badge"></span>
        </div>
      </div>
      <div class="col-md-8">
        <h3 id="liveTitle" class="mb-2"></h3>
        <p class="text-muted mb-3" style="font-size: 0.9rem;">
          <i class="fas fa-user me-1"></i> <span id="liveUploader"></span>
        </p>

        <!-- Live Status Info -->
        <div class="glass-card p-3 mb-3" id="liveStatusCard">
          <div class="d-flex align-items-center gap-3">
            <div id="liveIndicator" class="live-indicator">
              <span class="live-dot"></span>
            </div>
            <div>
              <h5 id="liveStatusText" class="mb-0"></h5>
              <small id="liveStatusDesc" class="text-muted"></small>
            </div>
          </div>
        </div>

        <!-- Recording Options -->
        <h5 class="mb-3" style="font-weight: 700;">Recording Options</h5>

        <div class="row g-3 mb-3">
          <!-- Duration -->
          <div class="col-md-6">
            <label class="form-label">Recording Duration (seconds)</label>
            <div class="input-group">
              <span class="input-group-text glass-input-icon"><i class="fas fa-stopwatch"></i></span>
              <input type="number" id="liveDuration" class="form-control glass-input" placeholder="e.g., 300 (5 min)" min="10" max="3600">
            </div>
            <small class="text-muted">Leave empty to download full stream/recording. Max: 3600s (1hr)</small>
          </div>

          <!-- From Start -->
          <div class="col-md-6">
            <label class="form-label">Start Position</label>
            <div class="row g-2">
              <div class="col-6">
                <div class="glass-card format-select-card p-2 text-center active" data-from-start="false" id="liveCurrentCard">
                  <i class="fas fa-forward me-1"></i>
                  <small>Current</small>
                </div>
              </div>
              <div class="col-6">
                <div class="glass-card format-select-card p-2 text-center" data-from-start="true" id="liveStartCard">
                  <i class="fas fa-step-backward me-1"></i>
                  <small>From Start</small>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Download Button -->
        <button class="btn btn-accent btn-lg w-100" id="downloadLiveBtn">
          <i class="fas fa-download me-2"></i> Download / Record
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Download Progress -->
<div id="liveDownloadProgress" class="glass-card p-4 d-none">
  <h4 class="mb-3" style="font-weight: 700;">
    <i class="fas fa-satellite-dish me-2 text-accent"></i>Recording Stream...
  </h4>
  <div class="progress progress-glow mb-3">
    <div id="liveDownloadBar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 100%; background-color: var(--danger);">
      Recording...
    </div>
  </div>
  <p class="text-muted mb-0 small">Recording in progress. This may take a while depending on duration...</p>
</div>

<script src="/js/live.js"></script>
