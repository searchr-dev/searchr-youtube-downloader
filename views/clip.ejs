<!-- Timestamp Downloader Page — Searchr YouTube Downloader -->

<div class="page-header">
  <h1 class="page-title">
    Timestamp Downloader
  </h1>
  <p class="page-subtitle">Download a specific time range from any YouTube video</p>
</div>

<!-- URL Input -->
<div class="glass-card p-4 mb-4">
  <div class="input-group input-group-lg">
    <span class="input-group-text glass-input-icon">
      <i class="fab fa-youtube text-danger"></i>
    </span>
    <input
      type="url"
      id="clipUrl"
      class="form-control glass-input"
      placeholder="Paste YouTube URL here..."
      autocomplete="off"
    >
    <button class="btn btn-accent" type="button" id="fetchClipBtn">
      <i class="fas fa-search me-1"></i> Fetch Info
    </button>
  </div>
</div>

<!-- Loading Spinner -->
<div id="clipLoading" class="text-center py-5 d-none">
  <div class="spinner-glow">
    <div class="spinner-border text-accent" role="status">
      <span class="visually-hidden">Loading...</span>
    </div>
  </div>
  <p class="mt-3 text-muted">Fetching video information...</p>
</div>

<!-- Clip Info Card -->
<div id="clipInfoCard" class="d-none">
  <div class="glass-card p-4 mb-4">
    <div class="row g-4 align-items-center">
      <div class="col-md-4">
        <div class="thumbnail-wrapper">
          <img id="clipThumb" src="" alt="Thumbnail" class="img-fluid rounded-3">
          <span id="clipFullDuration" class="duration-badge"></span>
        </div>
      </div>
      <div class="col-md-8">
        <h3 id="clipTitle" class="mb-3"></h3>
        <p class="text-muted mb-3" style="font-size: 0.9rem;">
          <i class="fas fa-user me-1"></i> <span id="clipUploader"></span>
        </p>

        <!-- Time Range Inputs -->
        <div class="glass-card p-3 mb-3">
          <h5 class="mb-3" style="font-weight: 700;">Select Time Range</h5>
          <div class="row g-3">
            <div class="col-md-5">
              <label class="form-label">Start Time</label>
              <div class="input-group">
                <span class="input-group-text glass-input-icon"><i class="fas fa-play" style="color: var(--success);"></i></span>
                <input type="text" id="clipStart" class="form-control glass-input" placeholder="00:00:00" value="00:00:00">
              </div>
            </div>
            <div class="col-md-2 d-flex align-items-end justify-content-center">
              <i class="fas fa-arrow-right fa-lg text-accent mb-2"></i>
            </div>
            <div class="col-md-5">
              <label class="form-label">End Time</label>
              <div class="input-group">
                <span class="input-group-text glass-input-icon"><i class="fas fa-stop text-danger"></i></span>
                <input type="text" id="clipEnd" class="form-control glass-input" placeholder="00:00:00">
              </div>
            </div>
          </div>
          <div class="mt-2">
            <small class="text-muted">
              <i class="fas fa-info-circle me-1"></i>
              Format: HH:MM:SS (e.g., 00:03:00 to 00:10:00). Video duration: <span id="clipDurationText" class="text-accent" style="font-family: var(--font-mono);">—</span>
            </small>
          </div>
        </div>

        <!-- Clip Type Selection -->
        <h5 class="mb-3" style="font-weight: 700;">Output Type</h5>
        <div class="row g-3 mb-3">
          <div class="col-6">
            <div class="glass-card format-select-card p-3 text-center active" data-type="video" id="clipVideoCard">
              <i class="fas fa-video fa-2x mb-2 text-accent"></i>
              <h6>Video Clip</h6>
              <p class="text-muted small mb-0">MP4 with audio</p>
            </div>
          </div>
          <div class="col-6">
            <div class="glass-card format-select-card p-3 text-center" data-type="audio" id="clipAudioCard">
              <i class="fas fa-music fa-2x mb-2" style="color: var(--accent-live);"></i>
              <h6>Audio Only</h6>
              <p class="text-muted small mb-0">MP3 extracted</p>
            </div>
          </div>
        </div>

        <!-- Video Quality Selection -->
        <div id="clipQualitySection" class="glass-card p-3 mb-4">
          <h5 class="mb-2" style="font-weight: 700;">Video Quality</h5>
          <select id="clipQuality" class="form-select glass-input">
            <option value="best" selected>Best Quality (Auto)</option>
            <option value="2160">2160p (4K)</option>
            <option value="1440">1440p (2K)</option>
            <option value="1080">1080p (Full HD)</option>
            <option value="720">720p (HD)</option>
            <option value="480">480p</option>
            <option value="360">360p</option>
            <option value="240">240p</option>
            <option value="144">144p</option>
          </select>
        </div>

        <!-- Download Button -->
        <button class="btn btn-accent btn-lg w-100" id="downloadClipBtn">
          <i class="fas fa-cut me-2"></i> Download Clip
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Download Progress -->
<div id="clipDownloadProgress" class="glass-card p-4 d-none">
  <h4 class="mb-3" style="font-weight: 700;">
    <i class="fas fa-scissors me-2 text-accent"></i>Creating Clip...
  </h4>
  <div class="progress progress-glow mb-3">
    <div id="clipDownloadBar" class="progress-bar progress-bar-striped progress-bar-animated bg-accent" role="progressbar" style="width: 100%">
      Processing...
    </div>
  </div>
  <p id="clipDownloadStatus" class="text-muted mb-0 small">Downloading and trimming your clip. This may take a moment...</p>
  <button id="cancelClipBtn" class="btn btn-danger-glass btn-sm mt-3 w-100 d-none">
    <i class="fas fa-times me-1"></i> Stop Download
  </button>
</div>

<script src="/js/clip.js"></script>
