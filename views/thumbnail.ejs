<!-- Thumbnail Extractor Page — Searchr YouTube Downloader -->

<div class="page-header">
  <h1 class="page-title">
    Thumbnail Downloader
  </h1>
  <p class="page-subtitle">Extract high-quality thumbnails from any YouTube video</p>
</div>

<!-- URL Input -->
<div class="glass-card p-4 mb-4">
  <div class="input-group input-group-lg">
    <span class="input-group-text glass-input-icon">
      <i class="fab fa-youtube text-danger"></i>
    </span>
    <input
      type="url"
      id="thumbnailUrl"
      class="form-control glass-input"
      placeholder="Paste YouTube URL here..."
      autocomplete="off"
    >
    <button class="btn btn-accent" type="button" id="fetchThumbnailBtn">
      <i class="fas fa-search me-1"></i> Fetch Info
    </button>
  </div>
</div>

<!-- Loading Spinner -->
<div id="thumbnailLoading" class="text-center py-5 d-none">
  <div class="spinner-glow">
    <div class="spinner-border text-accent" role="status">
      <span class="visually-hidden">Loading...</span>
    </div>
  </div>
  <p class="mt-3 text-muted">Fetching thumbnail information...</p>
</div>

<!-- Thumbnail Info Card -->
<div id="thumbnailInfoCard" class="d-none">
  <div class="glass-card p-4 mb-4">
    <div class="row mb-4 align-items-center">
      <div class="col-md-3">
        <img id="mainThumb" src="" alt="Video Thumbnail" class="img-fluid rounded-3">
      </div>
      <div class="col-md-9">
        <h3 id="videoTitle" class="mb-2"></h3>
        <p class="text-muted mb-0" style="font-size: 0.9rem;">
          <i class="fas fa-user me-1"></i> <span id="videoUploader"></span>
        </p>
      </div>
    </div>
    
    <!-- Thumbnails Grid -->
    <h4 class="mb-3" style="font-weight: 700;">
      <i class="fas fa-image me-2 text-accent"></i>Available Thumbnails
    </h4>
    <div class="row g-4" id="thumbnailsGrid">
      <!-- Populated by JS -->
    </div>
  </div>
</div>

<script src="/js/thumbnail.js"></script>
